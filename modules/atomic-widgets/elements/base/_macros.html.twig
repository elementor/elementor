{%- macro render_base_classes(id, base_styles, settings, extra_classes) -%}
{{- ['elementor-element', 'elementor-element-' ~ id, 'e-con', 'e-atomic-element', base_styles.base] | merge(settings.classes | default([])) | merge(extra_classes | default([])) | join(' ') -}}
{%- endmacro -%}

{%- macro render_data_attributes(id, type, interaction_id) -%}
data-id="{{ id }}" data-element_type="{{ type }}" data-e-type="{{ type }}" data-interaction-id="{{ interaction_id }}"
{%- endmacro -%}

{%- macro render_custom_attributes(settings, editor_attributes) -%}
{% if settings._cssid is defined and settings._cssid is not empty %} id="{{ settings._cssid | e }}"{% endif %}
{%- if settings.attributes is defined and settings.attributes is not empty %} {{ settings.attributes | raw }}{% endif %}
{%- if editor_attributes is defined and editor_attributes is not empty %} {{ editor_attributes | raw }}{% endif %}
{%- endmacro -%}

{%- macro render_link_attributes(settings, tag) -%}
{%- if settings.link is defined and settings.link.href is defined and settings.link.href is not empty -%}
{%- if tag == 'button' %} data-action-link="{{ settings.link.href | e }}"{% else %} href="{{ settings.link.href | e }}"{% endif -%}
{%- if settings.link.target is defined and settings.link.target is not empty %} target="{{ settings.link.target | e }}"{% endif -%}
{%- endif -%}
{%- endmacro -%}

{%- macro render_interactions(interactions) -%}
data-interactions="{{ interactions | json_encode | e('html_attr') }}"
{%- endmacro -%}
