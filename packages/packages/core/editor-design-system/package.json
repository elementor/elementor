{
	"name": "@elementor/editor-design-system",
	"version": "4.1.0",
	"private": true,
	"author": "Elementor Team",
	"homepage": "https://elementor.com/",
	"license": "GPL-3.0-or-later",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/elementor/elementor.git",
		"directory": "packages/core/editor-design-system"
	},
	"bugs": {
		"url": "https://github.com/elementor/elementor/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"README.md",
		"CHANGELOG.md",
		"/dist",
		"/src",
		"!**/__tests__"
	],
	"scripts": {
		"build": "tsup --config=../../tsup.build.ts",
		"dev": "tsup --config=../../tsup.dev.ts"
	},
	"dependencies": {
		"@elementor/editor": "4.1.0",
		"@elementor/editor-app-bar": "4.1.0",
		"@elementor/editor-documents": "4.1.0",
		"@elementor/editor-global-classes": "4.1.0",
		"@elementor/editor-panels": "4.1.0",
		"@elementor/editor-ui": "4.1.0",
		"@elementor/editor-variables": "4.1.0",
		"@elementor/editor-v1-adapters": "4.1.0",
		"@elementor/icons": "~1.75.1",
		"@elementor/ui": "1.37.5",
		"@wordpress/i18n": "^5.13.0"
	},
	"peerDependencies": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"tsup": "^8.3.5"
	}
}