{
  "name": "@elementor/editor-v5",
  "description": "Elementor Editor V5 proof of concept",
  "version": "4.3.0",
  "private": true,
  "author": "Elementor Team",
  "homepage": "https://elementor.com/",
  "license": "GPL-3.0-or-later",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elementor/elementor.git",
    "directory": "packages/apps/editor-v5"
  },
  "files": [
    "/dist",
    "/src",
    "!**/__tests__"
  ],
  "scripts": {
    "build": "tsup --config=../../tsup.build.ts",
    "dev": "tsup --config=../../tsup.dev.ts"
  },
  "dependencies": {
    "@elementor/editor-v5-agent": "4.3.0",
    "@elementor/editor-v5-runtime": "4.3.0",
    "@elementor/editor-v5-store": "4.3.0",
    "@elementor/query": "4.3.0",
    "@elementor/store": "4.3.0",
    "@elementor/ui": "1.37.5"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  }
}
