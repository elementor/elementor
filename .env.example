USERNAME=admin
PASSWORD=password
BASE_URL=http://127.0.0.1:9400
ELEMENTS_REGRESSION_BASE_URL=http://localhost:8889

# Environment: "local" (default) | "stg" | "prod"
ENV=local

# Cloudflare Zero Trust - required when ENV=stg or ENV=prod
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Staging WordPress URLs (used when ENV=stg)
WP_BASE_URL_STG=https://wp.stg.elementor.red
WP_TEST_SERVER_STG=https://wp.stg.elementor.red
